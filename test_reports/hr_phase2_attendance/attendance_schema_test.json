{
  "collection": "attendance_logs",
  "fields": {
    "id": "string (UUID)",
    "employee_id": "string (ref: employees.id)",
    "employee_nik": "string",
    "employee_name": "string",
    "department_id": "string",
    "department_name": "string",
    "branch_id": "string",
    "date": "string (YYYY-MM-DD)",
    "check_in": "string (ISO datetime)",
    "check_in_time": "string (HH:MM:SS)",
    "check_in_method": "string (manual|fingerprint|face|gps)",
    "check_in_location": "string",
    "check_in_lat": "float",
    "check_in_lng": "float",
    "check_in_notes": "string",
    "check_out": "string (ISO datetime)",
    "check_out_time": "string (HH:MM:SS)",
    "check_out_method": "string",
    "shift_id": "string",
    "shift_name": "string",
    "is_late": "boolean",
    "late_minutes": "integer",
    "work_hours": "float",
    "overtime_hours": "float",
    "status": "string (present|absent|leave|sick|holiday)",
    "created_by": "string",
    "created_at": "string (ISO datetime)"
  },
  "status_types": ["present", "absent", "leave", "sick", "holiday"],
  "check_in_methods": ["manual", "fingerprint", "face", "gps"]
}
